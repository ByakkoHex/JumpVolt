<UserControl x:Class="SklepMotoryzacyjny.Views.ReturnsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:SklepMotoryzacyjny.Converters"
             Background="{StaticResource BackgroundBrush}">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" MinWidth="380"/>
            <ColumnDefinition Width="420"/>
        </Grid.ColumnDefinitions>

        <!-- ===== LEWA: Szukaj sprzedaży + lista ===== -->
        <DockPanel Grid.Column="0" Margin="0,0,10,0">

            <!-- Filtry -->
            <Border DockPanel.Dock="Top" Style="{StaticResource CardPanel}" Padding="14,10">
                <StackPanel>
                    <TextBlock Text="↩ ZWROTY" Style="{StaticResource HeaderStyle}" Margin="0,0,0,10"/>

                    <!-- Filtry dat -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock Text="Od:" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold" Margin="0,0,6,0"/>
                        <DatePicker SelectedDate="{Binding DateFrom}" Width="150" FontSize="14" Margin="0,0,14,0"/>
                        <TextBlock Text="Do:" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold" Margin="0,0,6,0"/>
                        <DatePicker SelectedDate="{Binding DateTo}" Width="150" FontSize="14" Margin="0,0,14,0"/>
                        <Button Content="Dziś" Style="{StaticResource PrimaryButton}" Command="{Binding TodayCommand}" Padding="12,6" MinHeight="36"/>
                        <Button Content="Tydzień" Style="{StaticResource PrimaryButton}" Command="{Binding ThisWeekCommand}" Padding="12,6" MinHeight="36"/>
                        <Button Content="Miesiąc" Style="{StaticResource PrimaryButton}" Command="{Binding ThisMonthCommand}" Padding="12,6" MinHeight="36"/>
                    </StackPanel>

                    <!-- Szukaj po numerze paragonu -->
                    <DockPanel>
                        <Button DockPanel.Dock="Right" Content="Szukaj" Style="{StaticResource PrimaryButton}"
                                Command="{Binding SearchSalesCommand}" Margin="6,0,0,0" MinWidth="90"/>
                        <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="14">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Return" Command="{Binding SearchSalesCommand}"/>
                            </TextBox.InputBindings>
                        </TextBox>
                    </DockPanel>
                    <TextBlock Text="Wyszukaj po numerze paragonu lub zostaw puste — wyświetlą się sprzedaże z wybranego okresu."
                               FontSize="11" Foreground="#9E9E9E" Margin="0,3,0,0"/>
                </StackPanel>
            </Border>

            <!-- Lista zwrotów (ostatnie 30 dni) -->
            <Border DockPanel.Dock="Bottom" Style="{StaticResource CardPanel}" Padding="0" Margin="0,6,0,0" MaxHeight="170">
                <DockPanel>
                    <DockPanel DockPanel.Dock="Top" Margin="14,10,14,4">
                        <TextBlock Text="Ostatnie zwroty (30 dni)" Style="{StaticResource SubHeaderStyle}" VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Border Background="#FFEBEE" CornerRadius="6" Padding="10,4" Margin="0,0,8,0">
                                <TextBlock Text="{Binding RecentReturnsCount, StringFormat='{}Szt: {0}'}" FontSize="13" FontWeight="Bold" Foreground="#C62828"/>
                            </Border>
                            <Border Background="#FFEBEE" CornerRadius="6" Padding="10,4">
                                <TextBlock Text="{Binding RecentReturnsTotalDisplay}" FontSize="13" FontWeight="Bold" Foreground="#C62828"/>
                            </Border>
                        </StackPanel>
                    </DockPanel>
                    <DataGrid ItemsSource="{Binding RecentReturns}" SelectedItem="{Binding SelectedReturn}"
                              Margin="6,0,6,6" ColumnHeaderHeight="34" RowHeight="32">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Nr zwrotu" Binding="{Binding ReturnNumber}" Width="*" MinWidth="130"/>
                            <DataGridTextColumn Header="Paragon" Binding="{Binding OriginalReceiptNumber}" Width="130"/>
                            <DataGridTextColumn Header="Data" Binding="{Binding DateDisplay}" Width="125"/>
                            <DataGridTextColumn Header="Kwota" Binding="{Binding TotalDisplay}" Width="95">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="Foreground" Value="#C62828"/>
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                        <Setter Property="Padding" Value="6,0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Forma" Binding="{Binding RefundMethod}" Width="75"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

            <!-- Lista sprzedaży do wyboru -->
            <Border Style="{StaticResource CardPanel}" Padding="0" Margin="0,6,0,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Wybierz paragon do zwrotu" Style="{StaticResource SubHeaderStyle}" Margin="14,10,14,6"/>
                    <DataGrid ItemsSource="{Binding Sales}" SelectedItem="{Binding SelectedSale}" Margin="6,0,6,6">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Nr paragonu" Binding="{Binding ReceiptNumber}" Width="*" MinWidth="140"/>
                            <DataGridTextColumn Header="Data" Binding="{Binding DateDisplay}" Width="135"/>
                            <DataGridTextColumn Header="Suma" Binding="{Binding TotalDisplay}" Width="100">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="Foreground" Value="#2E7D32"/>
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                        <Setter Property="Padding" Value="6,0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Płatność" Binding="{Binding PaymentMethod}" Width="80"/>
                            <DataGridTextColumn Header="Poz." Binding="{Binding ItemCount}" Width="45">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Center"/></Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>
        </DockPanel>

        <!-- ===== PRAWA: Pozycje + panel zwrotu ===== -->
        <DockPanel Grid.Column="1">

            <!-- Panel zwrotu (dół) -->
            <Border DockPanel.Dock="Bottom" Style="{StaticResource CardPanel}" Margin="0,6,0,0" Padding="14">
                <StackPanel>
                    <!-- Suma zwrotu -->
                    <Border Background="#FFEBEE" CornerRadius="8" Padding="14,10" Margin="0,0,0,10">
                        <DockPanel>
                            <TextBlock Text="ZWROT:" FontSize="20" FontWeight="Bold" Foreground="#C62828" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding ReturnTotalDisplay}" FontSize="28" FontWeight="Bold"
                                       Foreground="#B71C1C" HorizontalAlignment="Right"/>
                        </DockPanel>
                    </Border>

                    <TextBlock Text="Forma zwrotu pieniędzy:" Style="{StaticResource LabelStyle}"/>
                    <ComboBox ItemsSource="{Binding RefundMethods}" SelectedItem="{Binding SelectedRefundMethod}" Margin="0,0,0,8"/>

                    <Button Content="↩  WYKONAJ ZWROT" Style="{StaticResource DangerButton}"
                            Command="{Binding ProcessReturnCommand}"
                            FontSize="17" MinHeight="54" Margin="0,0,0,0"/>
                </StackPanel>
            </Border>

            <!-- Pozycje wybranego paragonu -->
            <Border Style="{StaticResource CardPanel}" Padding="0">
                <DockPanel>
                    <DockPanel DockPanel.Dock="Top" Margin="14,10,14,6">
                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                            <Button Content="Zaznacz wszystko" Style="{StaticResource PrimaryButton}"
                                    Command="{Binding SelectAllCommand}" FontSize="12" Padding="8,5" MinHeight="30" Margin="0,0,4,0"/>
                            <Button Content="Odznacz" Style="{StaticResource DangerButton}"
                                    Command="{Binding DeselectAllCommand}" FontSize="12" Padding="8,5" MinHeight="30"/>
                        </StackPanel>
                        <TextBlock Text="🧾 Pozycje paragonu" Style="{StaticResource SubHeaderStyle}" VerticalAlignment="Center"/>
                    </DockPanel>

                    <!-- Info gdy brak wybranego paragonu -->
                    <TextBlock Margin="14,20" FontSize="14" Foreground="#9E9E9E" TextAlignment="Center" TextWrapping="Wrap"
                               Text="← Wybierz paragon z listy po lewej, aby zobaczyć pozycje do zwrotu.">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedSale}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <DataGrid ItemsSource="{Binding ReturnItems}" Margin="6,0,6,6"
                              RowHeight="42" ColumnHeaderHeight="38"
                              CanUserAddRows="False" CanUserDeleteRows="False">
                        <DataGrid.Columns>
                            <!-- Checkbox zaznaczenia -->
                            <DataGridTemplateColumn Header="Zwr." Width="46">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Nazwa produktu -->
                            <DataGridTextColumn Header="Produkt" Binding="{Binding ProductName}" Width="*" MinWidth="110" IsReadOnly="True"/>

                            <!-- Ilość oryginalna -->
                            <DataGridTextColumn Header="Kup." Binding="{Binding OriginalQuantity}" Width="45" IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="Foreground" Value="#616161"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <!-- Ilość do zwrotu (edytowalna) -->
                            <DataGridTextColumn Header="Zwr.il." Width="55"
                                               Binding="{Binding ReturnQuantity, Mode=TwoWay, UpdateSourceTrigger=LostFocus}">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                                <DataGridTextColumn.EditingElementStyle>
                                    <Style TargetType="TextBox">
                                        <Setter Property="TextAlignment" Value="Center"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                    </Style>
                                </DataGridTextColumn.EditingElementStyle>
                            </DataGridTextColumn>

                            <!-- Cena jednostkowa -->
                            <DataGridTextColumn Header="Cena" Binding="{Binding UnitPriceDisplay}" Width="75" IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                        <Setter Property="Padding" Value="4,0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <!-- Wartość zwrotu -->
                            <DataGridTextColumn Header="Wartość" Binding="{Binding ReturnValueDisplay}" Width="85" IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="Foreground" Value="#C62828"/>
                                        <Setter Property="Padding" Value="4,0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>
        </DockPanel>
    </Grid>
</UserControl>
