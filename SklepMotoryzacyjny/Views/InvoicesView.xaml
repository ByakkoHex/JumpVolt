<UserControl x:Class="SklepMotoryzacyjny.Views.InvoicesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SklepMotoryzacyjny.ViewModels"
             xmlns:conv="clr-namespace:SklepMotoryzacyjny.Converters"
             Background="{StaticResource BackgroundBrush}">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="400"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ============================================= -->
        <!-- LEWA: Lista faktur                            -->
        <!-- ============================================= -->
        <Grid Grid.Column="0" Margin="0,0,8,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Nagłówek -->
            <Border Grid.Row="0" Style="{StaticResource CardPanel}" Padding="14,10" Margin="0,0,0,6">
                <StackPanel>
                    <TextBlock Text="🧾 FAKTURY" Style="{StaticResource HeaderStyle}" Margin="0,0,0,8"/>
                    <Button Content="+ Nowa faktura" Style="{StaticResource SuccessButton}"
                            Command="{Binding AddNewCommand}" MinHeight="36" FontSize="14"/>
                </StackPanel>
            </Border>

            <!-- Filtry -->
            <Border Grid.Row="1" Style="{StaticResource CardPanel}" Padding="12,10" Margin="0,0,0,6">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock Text="Od:" VerticalAlignment="Center" FontSize="13" Margin="0,0,6,0"/>
                        <DatePicker SelectedDate="{Binding FilterFrom}" Width="130" Margin="0,0,8,0"/>
                        <TextBlock Text="Do:" VerticalAlignment="Center" FontSize="13" Margin="0,0,6,0"/>
                        <DatePicker SelectedDate="{Binding FilterTo}" Width="130"/>
                    </StackPanel>
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="13" Padding="6,4">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="TextBox">
                                            <Border Background="White" BorderBrush="#BDBDBD" BorderThickness="1" CornerRadius="4">
                                                <ScrollViewer x:Name="PART_ContentHost" Margin="6,4"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                </StackPanel>
            </Border>

            <!-- Lista faktur -->
            <Border Grid.Row="2" Style="{StaticResource CardPanel}" Padding="0">
                <DataGrid ItemsSource="{Binding Invoices}"
                          SelectedItem="{Binding SelectedInvoice}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          GridLinesVisibility="Horizontal"
                          BorderThickness="0"
                          Background="White"
                          RowBackground="White"
                          AlternatingRowBackground="#F9F9F9"
                          FontSize="12"
                          HeadersVisibility="Column"
                          ColumnHeaderHeight="34"
                          RowHeight="32"
                          HorizontalScrollBarVisibility="Hidden">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#1565C0"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="Padding" Value="8,0"/>
                            <Setter Property="BorderThickness" Value="0"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Numer" Binding="{Binding InvoiceNumber}" Width="130"/>
                        <DataGridTextColumn Header="Data" Binding="{Binding DateDisplay}" Width="80"/>
                        <DataGridTextColumn Header="Nabywca" Binding="{Binding BuyerName}" Width="*"/>
                        <DataGridTextColumn Header="Kwota" Binding="{Binding TotalGrossDisplay}" Width="80">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Foreground" Value="#2E7D32"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Status" Binding="{Binding StatusDisplay}" Width="70"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>

        <!-- ============================================= -->
        <!-- PRAWA: Szczegóły / Formularz edycji          -->
        <!-- ============================================= -->
        <Grid Grid.Column="1">

            <!-- ===== WIDOK SZCZEGÓŁÓW (gdy nie edytujemy) ===== -->
            <Border Style="{StaticResource CardPanel}" Padding="16"
                    Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Brak zaznaczenia -->
                    <TextBlock Grid.Row="1" Text="Wybierz fakturę z listy lub kliknij '+ Nowa faktura'"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               FontSize="16" Foreground="#9E9E9E"
                               Visibility="{Binding CanEditSelected, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}"/>

                    <!-- Dane faktury -->
                    <StackPanel Grid.Row="0" Visibility="{Binding CanEditSelected, Converter={StaticResource BoolToVis}}">
                        <DockPanel Margin="0,0,0,12">
                            <TextBlock Text="{Binding SelectedInvoice.InvoiceNumber}"
                                       Style="{StaticResource HeaderStyle}" VerticalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="Edytuj" Style="{StaticResource PrimaryButton}"
                                        Command="{Binding EditCommand}" MinWidth="90" Margin="0,0,6,0"/>
                                <Button Content="PDF" Style="{StaticResource SuccessButton}"
                                        Command="{Binding GeneratePdfCommand}" MinWidth="90" Margin="0,0,6,0"/>
                                <Button Content="Wyslij e-mail" Style="{StaticResource PrimaryButton}"
                                        Background="#1565C0" Command="{Binding SendEmailCommand}" MinWidth="110" Margin="0,0,6,0"/>
                                <Button Content="Usun" Style="{StaticResource DangerButton}"
                                        Command="{Binding DeleteCommand}" MinWidth="80"/>
                            </StackPanel>
                        </DockPanel>

                        <!-- Status wysyłania -->
                        <TextBlock Text="{Binding EmailSendStatus}" FontSize="13" Foreground="#1565C0"
                                   Margin="0,0,0,8"
                                   Visibility="{Binding EmailSendStatus, Converter={StaticResource BoolToVis}}"/>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Nabywca -->
                            <Border Grid.Column="0" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,6,0">
                                <StackPanel>
                                    <TextBlock Text="NABYWCA" FontSize="11" FontWeight="Bold" Foreground="#9E9E9E" Margin="0,0,0,6"/>
                                    <TextBlock Text="{Binding SelectedInvoice.BuyerName}" FontSize="15" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding SelectedInvoice.BuyerNIP, StringFormat='NIP: {0}'}" FontSize="12" Margin="0,2,0,0"/>
                                    <TextBlock Text="{Binding SelectedInvoice.BuyerAddress}" FontSize="12"/>
                                    <TextBlock Text="{Binding SelectedInvoice.BuyerCity}" FontSize="12"/>
                                    <TextBlock Text="{Binding SelectedInvoice.BuyerEmail}" FontSize="12" Foreground="#1565C0"/>
                                </StackPanel>
                            </Border>

                            <!-- Platnosc -->
                            <Border Grid.Column="1" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6" Padding="12" Margin="6,0,0,0">
                                <StackPanel>
                                    <TextBlock Text="PLATNOSC" FontSize="11" FontWeight="Bold" Foreground="#9E9E9E" Margin="0,0,0,6"/>
                                    <TextBlock Text="{Binding SelectedInvoice.PaymentMethod}" FontSize="14" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding SelectedInvoice.DateDisplay, StringFormat='Data: {0}'}" FontSize="12" Margin="0,4,0,0"/>
                                    <TextBlock Text="{Binding SelectedInvoice.DueDateDisplay, StringFormat='Termin: {0}'}" FontSize="12"/>
                                    <TextBlock Text="{Binding SelectedInvoice.StatusDisplay}" FontSize="13" FontWeight="SemiBold" Foreground="#2E7D32" Margin="0,6,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- Kwoty -->
                        <Border Background="#1565C0" CornerRadius="8" Padding="16,10" Margin="0,0,0,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                    <TextBlock Text="NETTO" FontSize="11" Foreground="#90CAF9" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding SelectedInvoice.TotalNet, StringFormat='{}{0:N2} zł'}"
                                               FontSize="16" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                    <TextBlock Text="VAT" FontSize="11" Foreground="#90CAF9" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding SelectedInvoice.TotalVat, StringFormat='{}{0:N2} zł'}"
                                               FontSize="16" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                    <TextBlock Text="BRUTTO" FontSize="11" Foreground="#90CAF9" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding SelectedInvoice.TotalGrossDisplay}"
                                               FontSize="20" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Uwagi -->
                        <TextBlock Text="{Binding SelectedInvoice.Notes, StringFormat='Uwagi: {0}'}"
                                   FontSize="12" Foreground="#757575"
                                   Visibility="{Binding SelectedInvoice.Notes, Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ===== FORMULARZ EDYCJI ===== -->
            <Border Style="{StaticResource CardPanel}" Padding="0"
                    Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Nagłówek formularza -->
                    <Border Grid.Row="0" Background="#1565C0" Padding="16,10">
                        <DockPanel>
                            <TextBlock Text="{Binding EditFormTitle}" FontSize="16" FontWeight="Bold"
                                       Foreground="White" VerticalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="Zapisz" Style="{StaticResource SuccessButton}"
                                        Command="{Binding SaveCommand}" MinWidth="90" Margin="0,0,8,0"/>
                                <Button Content="Anuluj" Style="{StaticResource DangerButton}"
                                        Command="{Binding CancelCommand}" MinWidth="90"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <!-- Treść formularza -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="16">
                        <StackPanel>

                            <!-- Numer i data -->
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="160"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                    <TextBlock Text="Numer faktury" Style="{StaticResource LabelStyle}"/>
                                    <TextBox Text="{Binding EditInvoiceNumber, UpdateSourceTrigger=PropertyChanged}"
                                             FontSize="14" Padding="6,4" BorderBrush="#BDBDBD" BorderThickness="1"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="0,0,8,0">
                                    <TextBlock Text="Data wystawienia" Style="{StaticResource LabelStyle}"/>
                                    <DatePicker SelectedDate="{Binding EditInvoiceDate}" FontSize="13"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Termin platnosci" Style="{StaticResource LabelStyle}"/>
                                    <DatePicker SelectedDate="{Binding EditDueDate}" FontSize="13"/>
                                </StackPanel>
                            </Grid>

                            <!-- Nabywca -->
                            <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="DANE NABYWCY" FontSize="11" FontWeight="Bold"
                                               Foreground="#1565C0" Margin="0,0,0,8"/>
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="160"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                            <TextBlock Text="Nazwa nabywcy *" Style="{StaticResource LabelStyle}"/>
                                            <TextBox Text="{Binding EditBuyerName, UpdateSourceTrigger=PropertyChanged}"
                                                     FontSize="14" Padding="6,4" BorderBrush="#BDBDBD" BorderThickness="1"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="NIP" Style="{StaticResource LabelStyle}"/>
                                            <TextBox Text="{Binding EditBuyerNIP, UpdateSourceTrigger=PropertyChanged}"
                                                     FontSize="14" Padding="6,4" BorderBrush="#BDBDBD" BorderThickness="1"/>
                                        </StackPanel>
                                    </Grid>
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                            <TextBlock Text="Ulica i numer" Style="{StaticResource LabelStyle}"/>
                                            <TextBox Text="{Binding EditBuyerAddress, UpdateSourceTrigger=PropertyChanged}"
                                                     FontSize="13" Padding="6,4" BorderBrush="#BDBDBD" BorderThickness="1"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Kod i miasto" Style="{StaticResource LabelStyle}"/>
                                            <TextBox Text="{Binding EditBuyerCity, UpdateSourceTrigger=PropertyChanged}"
                                                     FontSize="13" Padding="6,4" BorderBrush="#BDBDBD" BorderThickness="1"/>
                                        </StackPanel>
                                    </Grid>
                                    <StackPanel>
                                        <TextBlock Text="Adres e-mail (do wysylki faktury)" Style="{StaticResource LabelStyle}"/>
                                        <TextBox Text="{Binding EditBuyerEmail, UpdateSourceTrigger=PropertyChanged}"
                                                 FontSize="13" Padding="6,4" BorderBrush="#BDBDBD" BorderThickness="1"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Platnosc -->
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="120"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                    <TextBlock Text="Metoda platnosci" Style="{StaticResource LabelStyle}"/>
                                    <ComboBox ItemsSource="{Binding PaymentMethods}"
                                              SelectedItem="{Binding EditPaymentMethod}"
                                              FontSize="13" Padding="6,4"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Dni platnosci" Style="{StaticResource LabelStyle}"/>
                                    <TextBox Text="{Binding EditPaymentDays, UpdateSourceTrigger=PropertyChanged}"
                                             FontSize="13" Padding="6,4" BorderBrush="#BDBDBD" BorderThickness="1"/>
                                </StackPanel>
                            </Grid>

                            <!-- Pozycje faktury -->
                            <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="POZYCJE FAKTURY" FontSize="11" FontWeight="Bold"
                                               Foreground="#1565C0" Margin="0,0,0,8"/>

                                    <!-- Dodaj nową pozycję -->
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="60"/>
                                            <ColumnDefinition Width="80"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" Text="{Binding NewItemName, UpdateSourceTrigger=PropertyChanged}"
                                                 FontSize="12" Padding="4,3" Margin="0,0,4,0"
                                                 BorderBrush="#BDBDBD" BorderThickness="1">
                                            <TextBox.InputBindings>
                                                <KeyBinding Key="Return" Command="{Binding AddItemCommand}"/>
                                            </TextBox.InputBindings>
                                        </TextBox>
                                        <ComboBox Grid.Column="1" ItemsSource="{Binding Units}"
                                                  SelectedItem="{Binding NewItemUnit}"
                                                  FontSize="12" Padding="4,3" Margin="0,0,4,0"/>
                                        <TextBox Grid.Column="2" Text="{Binding NewItemQuantity, UpdateSourceTrigger=PropertyChanged}"
                                                 FontSize="12" Padding="4,3" Margin="0,0,4,0"
                                                 BorderBrush="#BDBDBD" BorderThickness="1"
                                                 TextAlignment="Right"/>
                                        <TextBox Grid.Column="3" Text="{Binding NewItemUnitPriceNet, UpdateSourceTrigger=PropertyChanged}"
                                                 FontSize="12" Padding="4,3" Margin="0,0,4,0"
                                                 BorderBrush="#BDBDBD" BorderThickness="1"
                                                 TextAlignment="Right"/>
                                        <ComboBox Grid.Column="4" ItemsSource="{Binding VatRates}"
                                                  SelectedItem="{Binding NewItemVatRate}"
                                                  FontSize="12" Padding="4,3" Margin="0,0,4,0"/>
                                        <Button Grid.Column="5" Content="+ Dodaj" Style="{StaticResource SuccessButton}"
                                                Command="{Binding AddItemCommand}" FontSize="11" Padding="4,3"/>
                                    </Grid>

                                    <!-- Nagłówki kolumn -->
                                    <Grid Margin="0,0,0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="60"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="40"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Nazwa" FontSize="11" FontWeight="SemiBold" Foreground="#616161" Padding="4,2"/>
                                        <TextBlock Grid.Column="1" Text="Jedn." FontSize="11" FontWeight="SemiBold" Foreground="#616161" Padding="4,2" TextAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="Ilosc" FontSize="11" FontWeight="SemiBold" Foreground="#616161" Padding="4,2" TextAlignment="Right"/>
                                        <TextBlock Grid.Column="3" Text="Cena netto" FontSize="11" FontWeight="SemiBold" Foreground="#616161" Padding="4,2" TextAlignment="Right"/>
                                        <TextBlock Grid.Column="4" Text="VAT" FontSize="11" FontWeight="SemiBold" Foreground="#616161" Padding="4,2" TextAlignment="Center"/>
                                        <TextBlock Grid.Column="5" Text="Netto sum" FontSize="11" FontWeight="SemiBold" Foreground="#616161" Padding="4,2" TextAlignment="Right"/>
                                        <TextBlock Grid.Column="6" Text="Brutto sum" FontSize="11" FontWeight="SemiBold" Foreground="#616161" Padding="4,2" TextAlignment="Right"/>
                                        <TextBlock Grid.Column="7" Text="" FontSize="11" Padding="4,2"/>
                                    </Grid>

                                    <!-- Lista pozycji -->
                                    <ItemsControl ItemsSource="{Binding EditItems}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,1,0,1">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="70"/>
                                                        <ColumnDefinition Width="70"/>
                                                        <ColumnDefinition Width="90"/>
                                                        <ColumnDefinition Width="60"/>
                                                        <ColumnDefinition Width="80"/>
                                                        <ColumnDefinition Width="80"/>
                                                        <ColumnDefinition Width="40"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBox Grid.Column="0" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                                             FontSize="12" Padding="4,2" Margin="0,0,2,0"
                                                             BorderBrush="#E0E0E0" BorderThickness="1"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding Unit}"
                                                               FontSize="12" Padding="4,4" TextAlignment="Center"/>
                                                    <TextBox Grid.Column="2" Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}"
                                                             FontSize="12" Padding="4,2" Margin="0,0,2,0"
                                                             BorderBrush="#E0E0E0" BorderThickness="1"
                                                             TextAlignment="Right"/>
                                                    <TextBox Grid.Column="3" Text="{Binding UnitPriceNet, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}"
                                                             FontSize="12" Padding="4,2" Margin="0,0,2,0"
                                                             BorderBrush="#E0E0E0" BorderThickness="1"
                                                             TextAlignment="Right"/>
                                                    <TextBlock Grid.Column="4" Text="{Binding VatDisplay}"
                                                               FontSize="12" Padding="4,4" TextAlignment="Center"
                                                               Foreground="#1565C0" FontWeight="SemiBold"/>
                                                    <TextBlock Grid.Column="5" Text="{Binding TotalNet, StringFormat=N2}"
                                                               FontSize="12" Padding="4,4" TextAlignment="Right"/>
                                                    <TextBlock Grid.Column="6" Text="{Binding TotalGross, StringFormat=N2}"
                                                               FontSize="12" Padding="4,4" TextAlignment="Right"
                                                               FontWeight="SemiBold" Foreground="#2E7D32"/>
                                                    <Button Grid.Column="7"
                                                            Content="X"
                                                            FontSize="11"
                                                            Foreground="White"
                                                            Background="#C62828"
                                                            BorderThickness="0"
                                                            Padding="4,2"
                                                            Cursor="Hand"
                                                            Command="{Binding DataContext.RemoveItemCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding}"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <!-- Sumy -->
                            <Border Background="#E3F2FD" CornerRadius="6" Padding="14,10" Margin="0,0,0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="PODSUMOWANIE" FontSize="12"
                                               FontWeight="Bold" Foreground="#1565C0" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <StackPanel Margin="0,0,20,0">
                                            <TextBlock Text="Netto" FontSize="11" Foreground="#616161" HorizontalAlignment="Center"/>
                                            <TextBlock Text="{Binding TotalNetDisplay}" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,0,20,0">
                                            <TextBlock Text="VAT" FontSize="11" Foreground="#616161" HorizontalAlignment="Center"/>
                                            <TextBlock Text="{Binding TotalVatDisplay}" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock Text="Brutto" FontSize="11" Foreground="#1565C0" FontWeight="Bold" HorizontalAlignment="Center"/>
                                            <TextBlock Text="{Binding TotalGrossDisplay}" FontSize="18" FontWeight="Bold"
                                                       Foreground="#1565C0" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Uwagi -->
                            <StackPanel>
                                <TextBlock Text="Uwagi / notatka" Style="{StaticResource LabelStyle}"/>
                                <TextBox Text="{Binding EditNotes, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="13" Padding="6,4" BorderBrush="#BDBDBD" BorderThickness="1"
                                         MinHeight="60" AcceptsReturn="True" TextWrapping="Wrap"/>
                            </StackPanel>

                        </StackPanel>
                    </ScrollViewer>

                    <!-- Przyciski dolne -->
                    <Border Grid.Row="2" Padding="16,10" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Zapisz fakture" Style="{StaticResource SuccessButton}"
                                    Command="{Binding SaveCommand}" MinWidth="140" MinHeight="38" Margin="0,0,8,0"/>
                            <Button Content="Anuluj" Style="{StaticResource DangerButton}"
                                    Command="{Binding CancelCommand}" MinWidth="90" MinHeight="38"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
