<UserControl x:Class="SklepMotoryzacyjny.Views.HistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Nagłówek + Filtry -->
        <Border Grid.Row="0" Style="{StaticResource CardPanel}" Padding="16,12">
            <StackPanel>
                <DockPanel Margin="0,0,0,10">
                    <TextBlock Text="📋 HISTORIA SPRZEDAŻY" Style="{StaticResource HeaderStyle}" VerticalAlignment="Center"/>
                    
                    <!-- Raporty fiskalne -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="📄 Raport X" Style="{StaticResource PrimaryButton}" 
                                Command="{Binding PrintXReportCommand}" MinWidth="130"/>
                        <Button Content="📄 Raport Z" Style="{StaticResource DangerButton}" 
                                Command="{Binding PrintZReportCommand}" MinWidth="130"/>
                    </StackPanel>
                </DockPanel>

                <!-- Filtry dat -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="Od:" VerticalAlignment="Center" FontSize="16" FontWeight="SemiBold" Margin="0,0,8,0"/>
                    <DatePicker SelectedDate="{Binding DateFrom}" FontSize="16" Width="160" Margin="0,0,16,0"/>
                    <TextBlock Text="Do:" VerticalAlignment="Center" FontSize="16" FontWeight="SemiBold" Margin="0,0,8,0"/>
                    <DatePicker SelectedDate="{Binding DateTo}" FontSize="16" Width="160" Margin="0,0,16,0"/>
                    
                    <!-- Szybkie filtry -->
                    <Button Content="Dziś" Style="{StaticResource PrimaryButton}" 
                            Command="{Binding TodayCommand}" Padding="16,8" MinHeight="38" FontSize="14"/>
                    <Button Content="Ten tydzień" Style="{StaticResource PrimaryButton}" 
                            Command="{Binding ThisWeekCommand}" Padding="16,8" MinHeight="38" FontSize="14"/>
                    <Button Content="Ten miesiąc" Style="{StaticResource PrimaryButton}" 
                            Command="{Binding ThisMonthCommand}" Padding="16,8" MinHeight="38" FontSize="14"/>
                </StackPanel>

                <!-- Wyszukiwanie -->
                <DockPanel>
                    <Button DockPanel.Dock="Right" Content="Szukaj" Style="{StaticResource PrimaryButton}" 
                            Command="{Binding SearchCommand}" Margin="8,0,0,0" MinWidth="100"/>
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Return" Command="{Binding SearchCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>
                </DockPanel>
            </StackPanel>
        </Border>

        <!-- Tabele - sprzedaże i szczegóły -->
        <Grid Grid.Row="1" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="380"/>
            </Grid.ColumnDefinitions>

            <!-- Lista transakcji -->
            <Border Grid.Column="0" Style="{StaticResource CardPanel}" Padding="0" Margin="0,0,8,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Transakcje" Style="{StaticResource SubHeaderStyle}" Margin="16,12,16,8"/>
                    <DataGrid ItemsSource="{Binding Sales}" SelectedItem="{Binding SelectedSale}" Margin="8,0,8,8">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Nr paragonu" Binding="{Binding ReceiptNumber}" Width="150"/>
                            <DataGridTextColumn Header="Data" Binding="{Binding DateDisplay}" Width="140"/>
                            <DataGridTextColumn Header="Suma" Binding="{Binding TotalDisplay}" Width="110">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="Foreground" Value="#2E7D32"/>
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                        <Setter Property="Padding" Value="8,0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Płatność" Binding="{Binding PaymentMethod}" Width="90"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding StatusDisplay}" Width="110">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsCancelled}" Value="True">
                                                <Setter Property="Foreground" Value="#C62828"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

            <!-- Szczegóły transakcji -->
            <Border Grid.Column="1" Style="{StaticResource CardPanel}" Padding="0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Pozycje paragonu" Style="{StaticResource SubHeaderStyle}" Margin="16,12,16,8"/>
                    <DataGrid ItemsSource="{Binding SelectedSaleItems}" Margin="8,0,8,8"
                              RowHeight="40" ColumnHeaderHeight="42">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Produkt" Binding="{Binding ProductName}" Width="*"/>
                            <DataGridTextColumn Header="Ilość" Binding="{Binding Quantity}" Width="50">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Wartość" Binding="{Binding TotalPriceDisplay}" Width="90">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="Padding" Value="4,0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>
        </Grid>

        <!-- Statystyki -->
        <Border Grid.Row="2" Style="{StaticResource CardPanel}" Padding="16,12" Margin="0,8,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Border Background="#E8F5E9" CornerRadius="8" Padding="20,10" Margin="8,0">
                    <StackPanel>
                        <TextBlock Text="Łączna sprzedaż" FontSize="14" Foreground="#757575" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding TotalSalesDisplay}" FontSize="26" FontWeight="Bold" 
                                   Foreground="#1B5E20" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <Border Background="#FFF9C4" CornerRadius="8" Padding="20,10" Margin="8,0">
                    <StackPanel>
                        <TextBlock Text="Liczba transakcji" FontSize="14" Foreground="#757575" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding SalesCount}" FontSize="26" FontWeight="Bold" 
                                   Foreground="#1A1A1A" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <Border Background="#F5F5F5" CornerRadius="8" Padding="20,10" Margin="8,0">
                    <StackPanel>
                        <TextBlock Text="Średnia transakcja" FontSize="14" Foreground="#757575" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding AverageSaleDisplay}" FontSize="26" FontWeight="Bold" 
                                   Foreground="#424242" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
