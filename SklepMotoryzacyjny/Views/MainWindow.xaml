<Window x:Class="SklepMotoryzacyjny.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:SklepMotoryzacyjny.ViewModels"
        xmlns:views="clr-namespace:SklepMotoryzacyjny.Views"
        xmlns:conv="clr-namespace:SklepMotoryzacyjny.Converters"
        Title="JumpVolt - System Sprzedaży"
        Icon="/Resources/app.ico"
        WindowState="Maximized"
        MinWidth="1200" MinHeight="700"
        Background="{StaticResource BackgroundBrush}">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <DataTemplate DataType="{x:Type vm:SalesViewModel}"><views:SalesView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:ProductsViewModel}"><views:ProductsView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:HistoryViewModel}"><views:HistoryView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:ReturnsViewModel}"><views:ReturnsView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}"><views:SettingsView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:HelpViewModel}"><views:HelpView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:TestsViewModel}"><views:TestsView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:InvoicesViewModel}"><views:InvoicesView/></DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ============================================= -->
        <!-- SIDEBAR                                       -->
        <!-- ============================================= -->
        <Border Grid.Column="0" Background="#1A1A1A">
            <DockPanel>

                <!-- ===== LOGO ===== -->
                <Border DockPanel.Dock="Top">
                    <Image Source="/Resources/logo_full.png" 
                           Stretch="Uniform"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                </Border>

                <!-- ===== STATUS KASY — dół ===== -->
                <StackPanel DockPanel.Dock="Bottom" Margin="14,8,14,14">
                    <Border Height="1" Background="#333333" Margin="0,0,0,10"/>
                    <Border CornerRadius="10" Padding="12,10">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#2C2C2C"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsFiscalConnected}" Value="True">
                                        <Setter Property="Background" Value="#1B5E20"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding ConnectionStatus}" Foreground="White" 
                                   FontSize="13" FontWeight="Medium" HorizontalAlignment="Center"/>
                    </Border>

                    <!-- Data pod statusem -->
                    <Border Background="#2C2C2C" CornerRadius="8" Padding="10,6" Margin="0,8,0,0">
                        <TextBlock Text="{Binding TodayDate}" FontSize="11" Foreground="#BDBDBD" 
                                   HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
                    </Border>
                </StackPanel>

                <!-- ===== NAWIGACJA ===== -->
                <StackPanel Margin="10,16,10,0">
                    <TextBlock Text="MENU" FontSize="11" Foreground="#FFD600" Margin="14,0,0,10"
                               FontWeight="Bold"/>

                    <Button Content="🛒  SPRZEDAŻ"
                            Style="{StaticResource NavButton}" Command="{Binding ShowSalesCommand}"/>

                    <Button Content="📦  MAGAZYN"
                            Style="{StaticResource NavButton}" Command="{Binding ShowProductsCommand}"/>

                    <Button Content="📋  HISTORIA"
                            Style="{StaticResource NavButton}" Command="{Binding ShowHistoryCommand}"/>

                    <Button Content="↩  ZWROTY"
                            Style="{StaticResource NavButton}" Command="{Binding ShowReturnsCommand}"/>

                    <Button Content="🧾  FAKTURY"
                            Style="{StaticResource NavButton}" Command="{Binding ShowInvoicesCommand}"/>

                    <Button Content="⚙️  USTAWIENIA"
                            Style="{StaticResource NavButton}" Command="{Binding ShowSettingsCommand}"/>

                    <Border Height="1" Background="#333333" Margin="10,10,10,6"/>

                    <Button Content="🧪  TESTY"
                            Style="{StaticResource NavButton}" Command="{Binding ShowTestsCommand}"/>

                    <Button Content="📖  INSTRUKCJA"
                            Style="{StaticResource NavButton}" Command="{Binding ShowHelpCommand}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ============================================= -->
        <!-- GŁÓWNA ZAWARTOŚĆ                              -->
        <!-- ============================================= -->
        <DockPanel Grid.Column="1">
            <Border DockPanel.Dock="Bottom" Padding="16,7" BorderThickness="0,2,0,0">
                <Border.Background>
                    <SolidColorBrush Color="#FFF9C4"/>
                </Border.Background>
                <Border.BorderBrush>
                    <SolidColorBrush Color="#FFD600"/>
                </Border.BorderBrush>
                <Grid>
                    <TextBlock Text="{Binding StatusMessage}" FontSize="13" Foreground="#424242"/>
                    <TextBlock Text="{Binding CurrentViewName}" FontSize="13" FontWeight="Bold"
                               Foreground="#1A1A1A" HorizontalAlignment="Right"/>
                </Grid>
            </Border>
            <ContentControl Content="{Binding CurrentViewModel}"/>
        </DockPanel>
    </Grid>
</Window>
