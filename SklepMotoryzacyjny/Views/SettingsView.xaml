<UserControl x:Class="SklepMotoryzacyjny.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:SklepMotoryzacyjny.Converters"
             Background="{StaticResource BackgroundBrush}">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="12">
        <StackPanel MaxWidth="780" HorizontalAlignment="Center">

            <TextBlock Text="⚙️ USTAWIENIA" Style="{StaticResource HeaderStyle}" Margin="8,0,0,14"/>

            <!-- ============================================= -->
            <!-- DANE FIRMY                                    -->
            <!-- ============================================= -->
            <Border Style="{StaticResource CardPanel}">
                <StackPanel>
                    <TextBlock Text="⚡ Dane firmy — JumpVolt" Style="{StaticResource SubHeaderStyle}" Margin="0,0,0,10"/>
                    <TextBlock Text="Nazwa firmy / sklepu" Style="{StaticResource LabelStyle}"/>
                    <TextBox Text="{Binding CompanyName, UpdateSourceTrigger=PropertyChanged}" FontSize="19"/>
                    <TextBlock Text="NIP" Style="{StaticResource LabelStyle}"/>
                    <TextBox Text="{Binding CompanyNIP, UpdateSourceTrigger=PropertyChanged}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/><ColumnDefinition Width="12"/><ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Adres" Style="{StaticResource LabelStyle}"/>
                            <TextBox Text="{Binding CompanyAddress, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Miasto, kod" Style="{StaticResource LabelStyle}"/>
                            <TextBox Text="{Binding CompanyCity, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </Grid>
                    <TextBlock Text="Telefon" Style="{StaticResource LabelStyle}"/>
                    <TextBox Text="{Binding CompanyPhone, UpdateSourceTrigger=PropertyChanged}" Width="300" HorizontalAlignment="Left"/>
                </StackPanel>
            </Border>

            <!-- ============================================= -->
            <!-- KASA FISKALNA - COM / IP                      -->
            <!-- ============================================= -->
            <Border Style="{StaticResource CardPanel}" Margin="6,6,6,6">
                <StackPanel>
                    <TextBlock Text="🖨️ Kasa fiskalna — Novitus Nano Online" Style="{StaticResource SubHeaderStyle}" Margin="0,0,0,10"/>

                    <!-- Typ połączenia -->
                    <TextBlock Text="Typ połączenia z kasą" Style="{StaticResource LabelStyle}" FontWeight="Bold"/>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <RadioButton Content="  USB (port COM)" FontSize="16" Padding="6,4" Margin="0,0,12,0"
                                     IsChecked="{Binding IsFiscalCom, Mode=OneWay}" GroupName="FiscalConn"
                                     Checked="FiscalCom_Checked"/>
                        <RadioButton Grid.Column="1" Content="  Sieć (TCP/IP)" FontSize="16" Padding="6,4"
                                     IsChecked="{Binding IsFiscalIp, Mode=OneWay}" GroupName="FiscalConn"
                                     Checked="FiscalIp_Checked"/>
                    </Grid>

                    <!-- COM fields -->
                    <Border Background="#F5F5F5" CornerRadius="8" Padding="14,10" Margin="0,0,0,8"
                            Visibility="{Binding IsFiscalCom, Converter={StaticResource BoolToVis}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/><ColumnDefinition Width="12"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Port COM" Style="{StaticResource LabelStyle}"/>
                                <ComboBox ItemsSource="{Binding AvailablePorts}" SelectedItem="{Binding FiscalPort}" IsEditable="True"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Prędkość" Style="{StaticResource LabelStyle}"/>
                                <ComboBox ItemsSource="{Binding BaudRates}" SelectedItem="{Binding FiscalBaudRate}"/>
                            </StackPanel>
                            <Button Grid.Column="3" Content="🔄" Style="{StaticResource PrimaryButton}" Command="{Binding RefreshPortsCommand}"
                                    ToolTip="Odśwież porty" Padding="10,6" MinWidth="44" MinHeight="38" VerticalAlignment="Bottom" Margin="8,0,0,0"/>
                        </Grid>
                    </Border>

                    <!-- IP fields -->
                    <Border Background="#F5F5F5" CornerRadius="8" Padding="14,10" Margin="0,0,0,8"
                            Visibility="{Binding IsFiscalIp, Converter={StaticResource BoolToVis}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/><ColumnDefinition Width="12"/><ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Adres IP kasy" Style="{StaticResource LabelStyle}"/>
                                <TextBox Text="{Binding FiscalIpAddress, UpdateSourceTrigger=PropertyChanged}" FontSize="18" FontWeight="SemiBold"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Port TCP" Style="{StaticResource LabelStyle}"/>
                                <TextBox Text="{Binding FiscalIpPort, UpdateSourceTrigger=PropertyChanged}" FontSize="18"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Test + szuflada -->
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <Button Content="🔌 Testuj kasę" Style="{StaticResource PrimaryButton}" Command="{Binding TestFiscalCommand}" MinWidth="170"/>
                        <Button Content="🗃️ Otwórz szufladę" Style="{StaticResource AccentButton}" Command="{Binding OpenCashDrawerCommand}" MinWidth="170"/>
                    </StackPanel>

                    <!-- Wynik testu -->
                    <Border Background="#ECEFF1" CornerRadius="6" Padding="12,8" Margin="0,8,0,0">
                        <TextBlock Text="{Binding ConnectionTestResult}" FontSize="14" Foreground="#37474F" TextWrapping="Wrap"/>
                    </Border>

                    <CheckBox Content="  Automatycznie drukuj paragon fiskalny" IsChecked="{Binding AutoPrintReceipt}" FontSize="16" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>

            <!-- ============================================= -->
            <!-- TERMINAL PŁATNICZY - COM / IP                 -->
            <!-- ============================================= -->
            <Border Style="{StaticResource CardPanel}" Margin="6,0,6,6">
                <StackPanel>
                    <TextBlock Text="💳 Terminal płatniczy" Style="{StaticResource SubHeaderStyle}" Margin="0,0,0,10"/>

                    <!-- Typ połączenia -->
                    <TextBlock Text="Typ połączenia z terminalem" Style="{StaticResource LabelStyle}" FontWeight="Bold"/>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <RadioButton Content="  USB (port COM)" FontSize="16" Padding="6,4" Margin="0,0,12,0"
                                     IsChecked="{Binding IsTerminalCom, Mode=OneWay}" GroupName="TermConn"
                                     Checked="TerminalCom_Checked"/>
                        <RadioButton Grid.Column="1" Content="  Sieć (TCP/IP)" FontSize="16" Padding="6,4"
                                     IsChecked="{Binding IsTerminalIp, Mode=OneWay}" GroupName="TermConn"
                                     Checked="TerminalIp_Checked"/>
                    </Grid>

                    <!-- COM fields -->
                    <Border Background="#F5F5F5" CornerRadius="8" Padding="14,10" Margin="0,0,0,8"
                            Visibility="{Binding IsTerminalCom, Converter={StaticResource BoolToVis}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/><ColumnDefinition Width="12"/><ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Port COM" Style="{StaticResource LabelStyle}"/>
                                <ComboBox ItemsSource="{Binding AvailablePorts}" SelectedItem="{Binding TerminalComPort}" IsEditable="True"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Prędkość" Style="{StaticResource LabelStyle}"/>
                                <ComboBox ItemsSource="{Binding BaudRates}" SelectedItem="{Binding TerminalBaudRate}"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- IP fields -->
                    <Border Background="#F5F5F5" CornerRadius="8" Padding="14,10" Margin="0,0,0,8"
                            Visibility="{Binding IsTerminalIp, Converter={StaticResource BoolToVis}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/><ColumnDefinition Width="12"/><ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Adres IP terminala" Style="{StaticResource LabelStyle}"/>
                                <TextBox Text="{Binding TerminalIpAddress, UpdateSourceTrigger=PropertyChanged}" FontSize="18" FontWeight="SemiBold"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Port TCP" Style="{StaticResource LabelStyle}"/>
                                <TextBox Text="{Binding TerminalIpPort, UpdateSourceTrigger=PropertyChanged}" FontSize="18"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Test terminala -->
                    <Button Content="🔌 Testuj terminal" Style="{StaticResource PrimaryButton}" Command="{Binding TestTerminalCommand}" MinWidth="170" HorizontalAlignment="Left"/>
                    <Border Background="#ECEFF1" CornerRadius="6" Padding="12,8" Margin="0,8,0,0">
                        <TextBlock Text="{Binding TerminalTestResult}" FontSize="14" Foreground="#37474F" TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>
            </Border>

            <!-- ============================================= -->
            <!-- USTAWIENIA DOMYŚLNE                           -->
            <!-- ============================================= -->
            <Border Style="{StaticResource CardPanel}" Margin="6,0,6,6">
                <StackPanel>
                    <TextBlock Text="📋 Domyślne" Style="{StaticResource SubHeaderStyle}" Margin="0,0,0,10"/>
                    <StackPanel Width="200" HorizontalAlignment="Left">
                        <TextBlock Text="Domyślna stawka VAT" Style="{StaticResource LabelStyle}"/>
                        <ComboBox ItemsSource="{Binding VatRates}" SelectedItem="{Binding DefaultVatRate}"/>
                    </StackPanel>
                    <Border Background="#FFF8E1" CornerRadius="6" Padding="14,10" Margin="0,10,0,0">
                        <TextBlock FontSize="14" Foreground="#5D4037" TextWrapping="Wrap">
                            <Run FontWeight="SemiBold">Stawki VAT:</Run>
                            <Run Text=" A = 23%  ·  B = 8%  ·  C = 5%  ·  D = 0% (zwolniony)"/>
                        </TextBlock>
                    </Border>
                </StackPanel>
            </Border>

            <!-- ============================================= -->
            <!-- BAZA DANYCH                                   -->
            <!-- ============================================= -->
            <Border Style="{StaticResource CardPanel}" Margin="6,0,6,6">
                <StackPanel>
                    <TextBlock Text="🗄️ Baza danych" Style="{StaticResource SubHeaderStyle}" Margin="0,0,0,12"/>

                    <!-- Aktualnie aktywny tryb -->
                    <Border Background="#E8F5E9" CornerRadius="6" Padding="12,8" Margin="0,0,0,14">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Aktywny tryb: " FontSize="13" Foreground="#2E7D32"/>
                            <TextBlock Text="{Binding CurrentDatabaseInfo}" FontSize="13"
                                       FontWeight="SemiBold" Foreground="#1B5E20" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- Wybór trybu -->
                    <TextBlock Style="{StaticResource LabelStyle}" Margin="0,0,0,8">
                        Tryb przechowywania danych:
                    </TextBlock>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                        <RadioButton IsChecked="{Binding IsLocalDatabase}" Content="Lokalny  (na tym komputerze)"
                                     FontSize="15" VerticalContentAlignment="Center" Margin="0,0,28,0"/>
                        <RadioButton IsChecked="{Binding IsNetworkDatabase}" Content="Sieciowy  (na serwerze / NAS)"
                                     FontSize="15" VerticalContentAlignment="Center"/>
                    </StackPanel>

                    <!-- Ścieżka sieciowa — widoczna tylko w trybie Sieciowym -->
                    <StackPanel>
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsNetworkDatabase}" Value="False">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>

                        <TextBlock Style="{StaticResource LabelStyle}" Margin="0,0,0,4">
                            Ścieżka do pliku bazy na serwerze (UNC lub dysk sieciowy):
                        </TextBlock>
                        <TextBox Text="{Binding NetworkDatabasePath, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="15" Padding="10,8" Margin="0,0,0,8"
                                 FontFamily="Consolas"
                                 ToolTip="Np. \\SERWER\JumpVolt\jumpvolt.db  lub  Z:\jumpvolt.db"/>
                        <TextBlock FontSize="12" Foreground="#757575" Margin="0,0,0,10" TextWrapping="Wrap">
                            Przykłady: <Run FontFamily="Consolas" FontWeight="SemiBold">\\192.168.1.50\JumpVolt\jumpvolt.db</Run>
                            lub zmapowany dysk <Run FontFamily="Consolas" FontWeight="SemiBold">Z:\jumpvolt.db</Run>
                        </TextBlock>
                        <Button Content="📋  Skopiuj lokalną bazę na serwer"
                                Command="{Binding CopyToNetworkCommand}"
                                Style="{StaticResource PrimaryButton}"
                                HorizontalAlignment="Left" Height="40" FontSize="14" Padding="16,0"/>
                    </StackPanel>

                    <!-- Ostrzeżenie o restarcie -->
                    <Border Background="#FFF3E0" CornerRadius="6" Padding="12,10" Margin="0,14,0,0">
                        <TextBlock FontSize="12" Foreground="#E65100" TextWrapping="Wrap">
                            <Run FontWeight="Bold">⚠ Uwaga:</Run>
                            <Run>Zmiana trybu bazy danych wymaga ponownego uruchomienia aplikacji.</Run>
                            <Run>Po kliknięciu "Zapisz ustawienia" zamknij i uruchom JumpVolt ponownie.</Run>
                        </TextBlock>
                    </Border>
                </StackPanel>
            </Border>

            <!-- ============================================= -->
            <!-- SYSTEM                                        -->
            <!-- ============================================= -->
            <Border Style="{StaticResource CardPanel}" Margin="6,0,6,6">
                <StackPanel>
                    <TextBlock Text="🖥️ System" Style="{StaticResource SubHeaderStyle}" Margin="0,0,0,12"/>

                    <!-- Auto-connect -->
                    <CheckBox IsChecked="{Binding AutoConnectOnStart}" FontSize="16" Margin="0,0,0,4">
                        <TextBlock TextWrapping="Wrap" FontSize="16">
                            <Run FontWeight="SemiBold">Automatycznie połącz z kasą przy starcie</Run>
                        </TextBlock>
                    </CheckBox>
                    <Border Background="#E8F5E9" CornerRadius="6" Padding="12,7" Margin="0,0,0,14">
                        <TextBlock FontSize="12" Foreground="#2E7D32" TextWrapping="Wrap">
                            <Run FontWeight="SemiBold">Ustawienia połączenia są trwale zapisane.</Run>
                            <Run>Gdy opcja jest włączona, aplikacja automatycznie łączy się z kasą fiskalną przy każdym uruchomieniu — bez konieczności ręcznej konfiguracji.</Run>
                        </TextBlock>
                    </Border>

                    <!-- Autostart Windows -->
                    <CheckBox IsChecked="{Binding RunWithWindows}" FontSize="16" Margin="0,0,0,4">
                        <TextBlock TextWrapping="Wrap" FontSize="16">
                            <Run FontWeight="SemiBold">Uruchamiaj JumpVolt razem z Windows</Run>
                        </TextBlock>
                    </CheckBox>
                    <Border Background="#FFF9C4" CornerRadius="6" Padding="12,7">
                        <TextBlock FontSize="12" Foreground="#5D4037" TextWrapping="Wrap">
                            Aplikacja będzie uruchamiana automatycznie po zalogowaniu do systemu Windows (wpis do rejestru: HKCU\...\Run).
                            Zmiana jest aktywna po kliknięciu <Run FontWeight="SemiBold">Zapisz ustawienia</Run>.
                        </TextBlock>
                    </Border>
                </StackPanel>
            </Border>

            <!-- ============================================= -->
            <!-- AKTUALIZACJE                                  -->
            <!-- ============================================= -->
            <Border Style="{StaticResource CardPanel}" Margin="6,0,6,6">
                <StackPanel>
                    <TextBlock Text="🔄 Aktualizacje" Style="{StaticResource SubHeaderStyle}" Margin="0,0,0,12"/>
                    <TextBlock Style="{StaticResource LabelStyle}" Margin="0,0,0,4">
                        URL serwera aktualizacji
                    </TextBlock>
                    <TextBox Text="{Binding UpdateCheckUrl, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="15" Padding="10,8" Margin="0,0,0,10"
                             ToolTip="Adres pliku JSON z informacją o nowej wersji. Pozostaw puste aby wyłączyć."/>
                    <Border Background="#E3F2FD" CornerRadius="6" Padding="12,10">
                        <TextBlock FontSize="12" Foreground="#1565C0" TextWrapping="Wrap">
                            <Run FontWeight="SemiBold">Format pliku JSON na serwerze:</Run>
                            <LineBreak/>
                            <Run xml:space="preserve">{ "version": "1.1.0", "downloadUrl": "https://...", "changelog": "Opis zmian" }</Run>
                            <LineBreak/>
                            <LineBreak/>
                            Sprawdzenie aktualizacji i pobieranie dostępne są w sekcji <Run FontWeight="SemiBold">Testy</Run>.
                        </TextBlock>
                    </Border>
                </StackPanel>
            </Border>

            <!-- ZAPISZ -->
            <Button Content="💾  ZAPISZ  USTAWIENIA" Style="{StaticResource SuccessButton}"
                    Command="{Binding SaveCommand}" HorizontalAlignment="Center"
                    MinWidth="280" FontSize="20" MinHeight="58" Margin="0,6,0,20"/>

        </StackPanel>
    </ScrollViewer>
</UserControl>
