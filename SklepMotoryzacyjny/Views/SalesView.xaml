<UserControl x:Class="SklepMotoryzacyjny.Views.SalesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:SklepMotoryzacyjny.Converters"
             Background="{StaticResource BackgroundBrush}">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:FilePathToImageConverter x:Key="PathToImage"/>
    </UserControl.Resources>

    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" MinWidth="400"/>
            <ColumnDefinition Width="400"/>
        </Grid.ColumnDefinitions>

        <!-- LEWA - Produkty -->
        <DockPanel Grid.Column="0" Margin="0,0,10,0">
            
            <Border DockPanel.Dock="Top" Style="{StaticResource CardPanel}" Padding="14,10">
                <StackPanel>
                    <TextBlock Text="⚡ SPRZEDAŻ" Style="{StaticResource HeaderStyle}" Margin="0,0,0,10"/>
                    
                    <!-- Kod kreskowy -->
                    <DockPanel Margin="0,0,0,6">
                        <Button DockPanel.Dock="Right" Content="Dodaj" Style="{StaticResource PrimaryButton}"
                                Command="{Binding ScanBarcodeCommand}" Margin="6,0,0,0" MinWidth="100"/>
                        <TextBox Text="{Binding BarcodeText, UpdateSourceTrigger=PropertyChanged}" FontSize="19" FontWeight="SemiBold">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Return" Command="{Binding ScanBarcodeCommand}"/>
                            </TextBox.InputBindings>
                        </TextBox>
                    </DockPanel>
                    <TextBlock Text="Zeskanuj kod kreskowy lub wpisz i naciśnij Enter" FontSize="12" Foreground="#9E9E9E" Margin="0,0,0,6"/>

                    <!-- Wyszukiwanie + filtr kategorii -->
                    <DockPanel>
                        <Button DockPanel.Dock="Right" Content="Szukaj" Style="{StaticResource PrimaryButton}"
                                Command="{Binding SearchCommand}" Margin="6,0,0,0" MinWidth="90"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox ItemsSource="{Binding CategoryFilters}" SelectedItem="{Binding FilterCategory}" Margin="0,0,6,0" FontSize="14"/>
                            <TextBox Grid.Column="1" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Return" Command="{Binding SearchCommand}"/>
                                </TextBox.InputBindings>
                            </TextBox>
                        </Grid>
                    </DockPanel>
                </StackPanel>
            </Border>

            <!-- Lista produktów -->
            <Border Style="{StaticResource CardPanel}" Margin="0,6,0,0" Padding="0">
                <DataGrid ItemsSource="{Binding SearchResults}" SelectedItem="{Binding SelectedProduct}" Margin="6">
                    <DataGrid.InputBindings>
                        <MouseBinding MouseAction="LeftDoubleClick" 
                                      Command="{Binding QuickAddCommand}" CommandParameter="{Binding SelectedProduct}"/>
                    </DataGrid.InputBindings>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Kat." Binding="{Binding CategoryIcon}" Width="35">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock"><Setter Property="FontSize" Value="18"/></Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTemplateColumn Header="Foto" Width="42">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Image Source="{Binding ImageFullPath, Converter={StaticResource PathToImage}, ConverterParameter=36}" 
                                           Width="32" Height="32" Stretch="Uniform" Margin="1"
                                           RenderOptions.BitmapScalingMode="HighQuality"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Nazwa" Binding="{Binding Name}" Width="*" MinWidth="160"/>
                        <DataGridTextColumn Header="Marka" Binding="{Binding Brand}" Width="85"/>
                        <DataGridTextColumn Header="Cena" Binding="{Binding SalePriceDisplay}" Width="95">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="Foreground" Value="#2E7D32"/>
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="Padding" Value="6,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Stan" Binding="{Binding StockQuantity}" Width="50">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsLowStock}" Value="True">
                                            <Setter Property="Foreground" Value="#C62828"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </DockPanel>

        <!-- PRAWA - Koszyk -->
        <DockPanel Grid.Column="1">
            
            <!-- Panel płatności -->
            <Border DockPanel.Dock="Bottom" Style="{StaticResource CardPanel}" Margin="0,6,0,0" Padding="14">
                <StackPanel>
                    <Border Background="#E8F5E9" CornerRadius="8" Padding="14,10" Margin="0,0,0,10">
                        <DockPanel>
                            <TextBlock Text="SUMA:" FontSize="22" FontWeight="Bold" Foreground="#2E7D32" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding TotalDisplay}" FontSize="30" FontWeight="Bold" 
                                       Foreground="#1B5E20" HorizontalAlignment="Right"/>
                        </DockPanel>
                    </Border>

                    <!-- Rabat -->
                    <Border Background="#FFF3E0" CornerRadius="7" Padding="10,8" Margin="0,0,0,6">
                        <StackPanel>
                            <DockPanel>
                                <TextBlock Text="Rabat %:" FontSize="15" FontWeight="SemiBold" Foreground="#E65100" VerticalAlignment="Center"/>
                                <TextBox Text="{Binding DiscountPercent, StringFormat=N0, UpdateSourceTrigger=PropertyChanged}"
                                         Width="70" FontSize="17" TextAlignment="Center" HorizontalAlignment="Right" Padding="6,4"/>
                            </DockPanel>
                            <Border Visibility="{Binding HasDiscount, Converter={StaticResource BoolToVis}}" Margin="0,4,0,0">
                                <DockPanel>
                                    <TextBlock Text="Oszczędność:" FontSize="13" Foreground="#E65100"/>
                                    <TextBlock Text="{Binding DiscountAmountDisplay}" FontSize="14" FontWeight="Bold" Foreground="#E65100" HorizontalAlignment="Right"/>
                                </DockPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="Płatność:" Style="{StaticResource LabelStyle}"/>
                    <ComboBox ItemsSource="{Binding PaymentMethods}" SelectedItem="{Binding SelectedPayment}"/>

                    <!-- Info: terminal kartowy -->
                    <Border Background="#E3F2FD" CornerRadius="7" Padding="10,8" Margin="0,5,0,0"
                            Visibility="{Binding IsPaymentCard, Converter={StaticResource BoolToVis}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="💳" FontSize="18" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <StackPanel>
                                <TextBlock Text="Terminal kartowy" FontSize="13" FontWeight="SemiBold" Foreground="#0D47A1"/>
                                <TextBlock Text="Kasa fiskalna rejestruje płatność kartą (typ 1)."
                                           FontSize="11" Foreground="#1565C0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <StackPanel Visibility="{Binding IsPaymentCash, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="Zapłacono:" Style="{StaticResource LabelStyle}"/>
                        <TextBox Text="{Binding PaidAmount, StringFormat=N2, UpdateSourceTrigger=PropertyChanged}" FontSize="20" FontWeight="Bold"/>
                        <Border Background="#FFF9C4" CornerRadius="6" Padding="10,6" Margin="0,4,0,6">
                            <DockPanel>
                                <TextBlock Text="Reszta:" FontSize="17" FontWeight="SemiBold" Foreground="#1A1A1A"/>
                                <TextBlock Text="{Binding ChangeDisplay}" FontSize="20" FontWeight="Bold" Foreground="#1A1A1A" HorizontalAlignment="Right"/>
                            </DockPanel>
                        </Border>
                    </StackPanel>

                    <Button Content="💰  SPRZEDAJ  I  DRUKUJ" Style="{StaticResource SuccessButton}"
                            Command="{Binding FinalizeSaleCommand}" FontSize="18" MinHeight="58" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Koszyk -->
            <Border Style="{StaticResource CardPanel}" Padding="0">
                <DockPanel>
                    <DockPanel DockPanel.Dock="Top" Margin="14,10,14,6">
                        <TextBlock Text="🧾 Paragon" Style="{StaticResource SubHeaderStyle}" VerticalAlignment="Center"/>
                        <Button Content="Wyczyść" Style="{StaticResource DangerButton}" Command="{Binding ClearCartCommand}"
                                Padding="10,5" FontSize="13" MinHeight="32" MinWidth="70" HorizontalAlignment="Right"/>
                    </DockPanel>

                    <DockPanel DockPanel.Dock="Top" Margin="14,0,14,6">
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <Button Content="+ Dodaj" Style="{StaticResource PrimaryButton}"
                                    Command="{Binding AddToCartCommand}" FontSize="13" Padding="10,6" MinHeight="36" Margin="6,0,0,0"/>
                            <Button Content="🗑️ Usuń" Style="{StaticResource DangerButton}"
                                    Command="{Binding RemoveFromCartCommand}" FontSize="13" Padding="10,6" MinHeight="36" Margin="4,0,0,0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Ilość:" VerticalAlignment="Center" Margin="0,0,6,0" FontSize="14"/>
                            <TextBox Text="{Binding AddQuantity, UpdateSourceTrigger=PropertyChanged}" Width="55" FontSize="17" TextAlignment="Center" Padding="4,4"/>
                        </StackPanel>
                    </DockPanel>

                    <DataGrid ItemsSource="{Binding CartItems}" SelectedItem="{Binding SelectedCartItem}" Margin="6,0,6,6"
                              RowHeight="40" ColumnHeaderHeight="38">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Produkt" Binding="{Binding ProductName}" Width="*" MinWidth="120"/>
                            <DataGridTextColumn Header="Ilość" Binding="{Binding Quantity}" Width="45">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Center"/><Setter Property="FontWeight" Value="Bold"/></Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Cena" Binding="{Binding UnitPriceDisplay}" Width="80">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Right"/><Setter Property="Padding" Value="4,0"/></Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Wartość" Binding="{Binding TotalPriceDisplay}" Width="90">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Right"/><Setter Property="FontWeight" Value="Bold"/><Setter Property="Foreground" Value="#2E7D32"/><Setter Property="Padding" Value="4,0"/></Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>
        </DockPanel>
    </Grid>
</UserControl>
