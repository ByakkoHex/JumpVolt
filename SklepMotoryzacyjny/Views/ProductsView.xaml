<UserControl x:Class="SklepMotoryzacyjny.Views.ProductsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:SklepMotoryzacyjny.Converters"
             Background="{StaticResource BackgroundBrush}">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:FilePathToImageConverter x:Key="PathToImage"/>
    </UserControl.Resources>

    <Grid Margin="12">
        <!-- ============================================= -->
        <!-- WIDOK LISTY PRODUKTÓW                         -->
        <!-- ============================================= -->
        <DockPanel Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}">
            
            <!-- Nagłówek + Szukanie -->
            <Border DockPanel.Dock="Top" Style="{StaticResource CardPanel}" Padding="14,10">
                <StackPanel>
                    <DockPanel Margin="0,0,0,8">
                        <TextBlock Text="📦 MAGAZYN" Style="{StaticResource HeaderStyle}" VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <TextBlock VerticalAlignment="Center" Margin="0,0,16,0" FontSize="14">
                                <Run Text="Produktów: " FontWeight="SemiBold"/>
                                <Run Text="{Binding ProductCount, Mode=OneWay}" FontWeight="Bold" Foreground="#1A1A1A"/>
                            </TextBlock>
                            <TextBlock VerticalAlignment="Center" FontSize="14">
                                <Run Text="Niski stan: " FontWeight="SemiBold"/>
                                <Run Text="{Binding LowStockCount, Mode=OneWay}" FontWeight="Bold" Foreground="#C62828"/>
                            </TextBlock>
                        </StackPanel>
                    </DockPanel>

                    <!-- Filtry i szukanie -->
                    <DockPanel Margin="0,0,0,6">
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="8,0,0,0">
                            <Button Content="🔍 Szukaj" Style="{StaticResource PrimaryButton}" Command="{Binding SearchCommand}" MinWidth="100"/>
                            <Button Content="⚠️ Niski stan" Style="{StaticResource DangerButton}" Command="{Binding ShowLowStockCommand}" MinWidth="120"/>
                        </StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox ItemsSource="{Binding FilterCategories}" SelectedItem="{Binding FilterCategory}" Margin="0,0,8,0"/>
                            <TextBox Grid.Column="1" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Return" Command="{Binding SearchCommand}"/>
                                </TextBox.InputBindings>
                            </TextBox>
                        </Grid>
                    </DockPanel>

                    <!-- Przyciski akcji -->
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Right" Text="↑ zaznacz produkt, dwuklik = edytuj"
                                   FontSize="13" Foreground="#9E9E9E" FontStyle="Italic"
                                   VerticalAlignment="Center" Margin="8,0,4,0"/>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="➕ Nowy produkt" Style="{StaticResource SuccessButton}" Command="{Binding AddNewCommand}" MinWidth="180"/>
                            <Button Content="✏️ Edytuj" Style="{StaticResource PrimaryButton}" Command="{Binding EditCommand}" MinWidth="110"/>
                            <Button Content="📥 Przyjmij towar" Style="{StaticResource AccentButton}" Command="{Binding AddStockCommand}" MinWidth="160"/>
                            <Button Content="🗑️ Usuń" Style="{StaticResource DangerButton}" Command="{Binding DeleteCommand}" MinWidth="90"/>
                        </StackPanel>
                    </DockPanel>
                </StackPanel>
            </Border>

            <!-- Tabela produktów -->
            <Border Style="{StaticResource CardPanel}" Margin="0,6,0,0" Padding="0">
                <DataGrid x:Name="ProductsDataGrid"
                          ItemsSource="{Binding Products}" SelectedItem="{Binding SelectedProduct}" Margin="6"
                          MouseDoubleClick="ProductsDataGrid_MouseDoubleClick">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Kategoria" Binding="{Binding CategoryIcon}" Width="Auto">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontSize" Value="22"/>
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTemplateColumn Header="Foto" Width="Auto">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Image Source="{Binding ImageFullPath, Converter={StaticResource PathToImage}, ConverterParameter=40}" 
                                           Width="36" Height="36" Stretch="Uniform" Margin="2"
                                           RenderOptions.BitmapScalingMode="HighQuality"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Nazwa" Binding="{Binding Name}" Width="*" MinWidth="180"/>
                        <DataGridTextColumn Header="Marka" Binding="{Binding Brand}" Width="100"/>
                        <DataGridTextColumn Header="Szczegóły" Binding="{Binding AttributesSummary}" Width="200">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#616161"/>
                                    <Setter Property="FontSize" Value="13"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Cena" Binding="{Binding SalePriceDisplay}" Width="100">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="Foreground" Value="#2E7D32"/>
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="Padding" Value="6,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Stan" Binding="{Binding StockQuantity}" Width="55">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsLowStock}" Value="True">
                                            <Setter Property="Foreground" Value="#C62828"/>
                                            <Setter Property="Background" Value="#FFEBEE"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="VAT" Binding="{Binding VatRateDisplay}" Width="50"/>
                        <DataGridTextColumn Header="Kod" Binding="{Binding Barcode}" Width="110"/>
                        <DataGridTextColumn Header="PLU (kasa)" Binding="{Binding FiscalName}" Width="110">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#1565C0"/>
                                    <Setter Property="FontStyle" Value="Italic"/>
                                    <Setter Property="FontSize" Value="13"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </DockPanel>

        <!-- ============================================= -->
        <!-- FORMULARZ EDYCJI Z DYNAMICZNYMI POLAMI        -->
        <!-- ============================================= -->
        <ScrollViewer Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}"
                      VerticalScrollBarVisibility="Auto">
            <Border Style="{StaticResource CardPanel}" Padding="24" MaxWidth="850" HorizontalAlignment="Center" Margin="0,4">
                <StackPanel>
                    <!-- Nagłówek -->
                    <DockPanel Margin="0,0,0,12">
                        <TextBlock Text="{Binding EditFormTitle}" Style="{StaticResource HeaderStyle}" VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <TextBlock Text="{Binding CategoryIcon}" FontSize="32" Margin="0,0,8,0"/>
                            <TextBlock Text="{Binding CategoryFullName}" FontSize="18" FontWeight="SemiBold" 
                                       Foreground="#1A1A1A" VerticalAlignment="Center"/>
                        </StackPanel>
                    </DockPanel>

                    <!-- KATEGORIA -->
                    <Border Background="#FFF9C4" CornerRadius="8" Padding="14,10" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Kategoria produktu" FontSize="15" FontWeight="Bold" Foreground="#1A1A1A" Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{Binding CategoryTypes}" SelectedItem="{Binding EditCategoryType}" FontSize="18" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>

                    <!-- PODSTAWOWE DANE -->
                    <TextBlock Text="Nazwa produktu *" Style="{StaticResource LabelStyle}"/>
                    <TextBox Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}" FontSize="19" FontWeight="SemiBold"/>

                    <!-- Marka -->
                    <TextBlock Text="Marka" Style="{StaticResource LabelStyle}"/>
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <Button Content="+ Nowa marka"
                                    Command="{Binding AddBrandCommand}"
                                    Style="{StaticResource PrimaryButton}"
                                    FontSize="14" MinHeight="42" MinWidth="120" Margin="6,0,0,0" Padding="12,8"/>
                            <Button Content="🗑️ Usuń markę"
                                    Command="{Binding DeleteBrandCommand}"
                                    Style="{StaticResource DangerButton}"
                                    FontSize="14" MinHeight="42" MinWidth="120" Margin="4,0,0,0" Padding="12,8"/>
                        </StackPanel>
                        <ComboBox IsEditable="True" Text="{Binding EditBrand, UpdateSourceTrigger=PropertyChanged}"
                                  ItemsSource="{Binding Brands}" FontSize="17"/>
                    </DockPanel>

                    <Grid Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Kod kreskowy (EAN)" Style="{StaticResource LabelStyle}"/>
                            <TextBox Text="{Binding EditBarcode, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Numer katalogowy" Style="{StaticResource LabelStyle}"/>
                            <TextBox Text="{Binding EditCatalogNumber, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </Grid>

                    <!-- ============================================= -->
                    <!-- NAZWA PLU — JAK ZAPROGRAMOWANE W KASIE        -->
                    <!-- ============================================= -->
                    <Border Background="#E3F2FD" CornerRadius="8" Padding="14,10" Margin="0,8,0,4">
                        <StackPanel>
                            <DockPanel Margin="0,0,0,4">
                                <TextBlock Text="🖨️ Nazwa PLU w kasie Novitus" FontSize="15" FontWeight="Bold" Foreground="#1565C0"/>
                                <TextBlock HorizontalAlignment="Right" FontSize="12" Foreground="#1565C0" VerticalAlignment="Center">
                                    <Run Text="{Binding EditFiscalName.Length, Mode=OneWay}" FontWeight="Bold"/>
                                    <Run Text=" / 40 znaków"/>
                                </TextBlock>
                            </DockPanel>
                            <TextBox Text="{Binding EditFiscalName, UpdateSourceTrigger=PropertyChanged}"
                                     MaxLength="40" FontSize="17" FontWeight="SemiBold"/>
                            <Border Background="#BBDEFB" CornerRadius="5" Padding="10,6" Margin="0,6,0,0">
                                <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="#0D47A1">
                                    <Run FontWeight="Bold">Wpisz dokładnie tak jak w kasie</Run>
                                    <Run Text=" — ta nazwa pojawi się na paragonie fiskalnym (max 40 znaków)."/>
                                    <LineBreak/>
                                    <Run Text="Zostaw puste, jeśli nazwa produktu jest już taka sama jak w kasie."/>
                                </TextBlock>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ============================================= -->
                    <!-- DYNAMICZNE POLA KATEGORII                     -->
                    <!-- ============================================= -->
                    <Border Background="#1A1A1A" CornerRadius="8" Padding="14,10" Margin="0,12,0,4">
                        <TextBlock Text="📋 Parametry techniczne" FontSize="16" FontWeight="Bold" Foreground="#FFD600"/>
                    </Border>

                    <ItemsControl ItemsSource="{Binding DynamicFields}" Margin="0,4,0,8">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,2,0,4">
                                    <TextBlock Text="{Binding LabelWithSuffix}" Style="{StaticResource LabelStyle}"/>
                                    
                                    <!-- Pole tekstowe / numeryczne -->
                                    <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                             Visibility="{Binding IsTextOrNumber, Converter={StaticResource BoolToVis}}"/>
                                    
                                    <!-- Lista rozwijana (nie edytowalna) -->
                                    <ComboBox ItemsSource="{Binding Options}" 
                                              SelectedItem="{Binding Value}"
                                              Visibility="{Binding IsDropdown, Converter={StaticResource BoolToVis}}"/>
                                    
                                    <!-- Lista rozwijana z możliwością wpisania -->
                                    <ComboBox IsEditable="True" 
                                              Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                              ItemsSource="{Binding Options}"
                                              Visibility="{Binding IsDropdownEditable, Converter={StaticResource BoolToVis}}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>

                        <!-- Układ 2-kolumnowy -->
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="2" HorizontalAlignment="Stretch"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemContainerStyle>
                            <Style>
                                <Setter Property="FrameworkElement.Margin" Value="0,0,8,0"/>
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                    </ItemsControl>

                    <!-- ============================================= -->
                    <!-- CENY I MAGAZYN                                -->
                    <!-- ============================================= -->
                    <Border Background="#E8F5E9" CornerRadius="8" Padding="14,10" Margin="0,4,0,4">
                        <TextBlock Text="💰 Ceny i magazyn" FontSize="16" FontWeight="Bold" Foreground="#2E7D32"/>
                    </Border>

                    <Grid Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="110"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="6"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Wiersz 1: Zakup netto | Sprzedaż brutto | VAT -->
                        <StackPanel Grid.Column="0" Grid.Row="0">
                            <TextBlock Text="Cena zakupu (netto)" Style="{StaticResource LabelStyle}"/>
                            <TextBox Text="{Binding EditPurchasePrice, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Grid.Row="0">
                            <TextBlock Text="Cena sprzedaży (brutto) *" Style="{StaticResource LabelStyle}" Foreground="#2E7D32" FontWeight="Bold"/>
                            <TextBox Text="{Binding EditSalePrice, UpdateSourceTrigger=PropertyChanged}" FontWeight="Bold" BorderBrush="#4CAF50"/>
                        </StackPanel>
                        <StackPanel Grid.Column="4" Grid.Row="0" Grid.RowSpan="3">
                            <TextBlock Text="VAT" Style="{StaticResource LabelStyle}"/>
                            <ComboBox ItemsSource="{Binding VatRates}" SelectedItem="{Binding EditVatRate}"/>
                        </StackPanel>

                        <!-- Wiersz 2: Zakup brutto (auto) | Sprzedaż netto (auto) -->
                        <StackPanel Grid.Column="0" Grid.Row="2">
                            <TextBlock Text="Cena zakupu (brutto)" Style="{StaticResource LabelStyle}" Foreground="#757575"/>
                            <TextBox Text="{Binding EditPurchasePriceGross, UpdateSourceTrigger=PropertyChanged}"
                                     Foreground="#555555" Background="#F5F5F5" BorderBrush="#BDBDBD"
                                     ToolTip="Wyliczone automatycznie — możesz też wpisać brutto, netto zostanie przeliczone"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Grid.Row="2">
                            <TextBlock Text="Cena sprzedaży (netto)" Style="{StaticResource LabelStyle}" Foreground="#757575"/>
                            <TextBox Text="{Binding EditSalePriceNet, UpdateSourceTrigger=PropertyChanged}"
                                     Foreground="#555555" Background="#F5F5F5" BorderBrush="#BDBDBD"
                                     ToolTip="Wyliczone automatycznie — możesz też wpisać netto, brutto zostanie przeliczone"/>
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="110"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Stan magazynowy" Style="{StaticResource LabelStyle}"/>
                            <TextBox Text="{Binding EditStockQuantity, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Minimalny stan (alert)" Style="{StaticResource LabelStyle}"/>
                            <TextBox Text="{Binding EditMinStockLevel, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="4">
                            <TextBlock Text="Jednostka" Style="{StaticResource LabelStyle}"/>
                            <ComboBox ItemsSource="{Binding Units}" SelectedItem="{Binding EditUnit}"/>
                        </StackPanel>
                    </Grid>

                    <!-- ============================================= -->
                    <!-- ZDJĘCIE PRODUKTU                              -->
                    <!-- ============================================= -->
                    <Border Background="#1A1A1A" CornerRadius="8" Padding="14,10" Margin="0,12,0,4">
                        <TextBlock Text="📸 Zdjęcie produktu" FontSize="16" FontWeight="Bold" Foreground="#FFD600"/>
                    </Border>

                    <Border Background="#F5F5F5" CornerRadius="10" Padding="16" Margin="0,4,0,4" MinHeight="120">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Podgląd zdjęcia -->
                            <Border Grid.Column="0" Width="180" Height="180" CornerRadius="8" 
                                    Background="White" BorderBrush="#BDBDBD" BorderThickness="2"
                                    Margin="0,0,16,0">
                                <!-- Zdjęcie -->
                                <Image Source="{Binding EditImagePath, Converter={StaticResource PathToImage}}"
                                       Stretch="Uniform" Margin="4"
                                       RenderOptions.BitmapScalingMode="HighQuality"
                                       Visibility="{Binding HasEditImage, Converter={StaticResource BoolToVis}}"/>
                            </Border>

                            <!-- Placeholder gdy brak zdjęcia (na tle tego samego Bordera) -->

                            <!-- Przyciski -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <Button Content="📷  Dodaj zdjęcie" 
                                        Style="{StaticResource PrimaryButton}"
                                        Command="{Binding AddImageCommand}" 
                                        MinWidth="180" HorizontalAlignment="Left"
                                        Margin="0,0,0,8"/>
                                <Button Content="🗑️  Usuń zdjęcie" 
                                        Style="{StaticResource DangerButton}"
                                        Command="{Binding RemoveImageCommand}" 
                                        MinWidth="180" HorizontalAlignment="Left"
                                        Visibility="{Binding HasEditImage, Converter={StaticResource BoolToVis}}"/>
                                <TextBlock Text="JPG, PNG, BMP — max zalecany rozmiar 2 MB" 
                                           FontSize="12" Foreground="#9E9E9E" Margin="4,8,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Notatki -->
                    <TextBlock Text="Notatki / uwagi" Style="{StaticResource LabelStyle}" Margin="0,8,0,0"/>
                    <TextBox Text="{Binding EditNotes, UpdateSourceTrigger=PropertyChanged}" 
                             MinHeight="60" TextWrapping="Wrap" AcceptsReturn="True"/>

                    <!-- Przyciski -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,18,0,0">
                        <Button Content="💾  ZAPISZ  PRODUKT" Style="{StaticResource SuccessButton}" 
                                Command="{Binding SaveCommand}" MinWidth="220" FontSize="19"/>
                        <Button Content="Anuluj" Style="{StaticResource DangerButton}" 
                                Command="{Binding CancelEditCommand}" MinWidth="130" Margin="12,0,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>
</UserControl>
