<Application x:Class="SklepMotoryzacyjny.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="Views/MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>

            <!-- ============================================= -->
            <!-- KOLORY JUMPVOLT — żółto-czarna paleta logo    -->
            <!-- ============================================= -->
            <Color x:Key="BrandYellow">#FFD600</Color>
            <Color x:Key="BrandYellowDark">#F9A825</Color>
            <Color x:Key="BrandYellowLight">#FFF9C4</Color>
            <Color x:Key="BrandBlack">#1A1A1A</Color>
            <Color x:Key="BrandDark">#212121</Color>
            <Color x:Key="BrandGray">#2C2C2C</Color>

            <Color x:Key="SuccessColor">#2E7D32</Color>
            <Color x:Key="DangerColor">#C62828</Color>
            <Color x:Key="AccentBlue">#1565C0</Color>
            <Color x:Key="BackgroundColor">#D6D6D6</Color>

            <SolidColorBrush x:Key="BrandYellowBrush" Color="{StaticResource BrandYellow}"/>
            <SolidColorBrush x:Key="BrandYellowDarkBrush" Color="{StaticResource BrandYellowDark}"/>
            <SolidColorBrush x:Key="BrandYellowLightBrush" Color="{StaticResource BrandYellowLight}"/>
            <SolidColorBrush x:Key="BrandBlackBrush" Color="{StaticResource BrandBlack}"/>
            <SolidColorBrush x:Key="BrandDarkBrush" Color="{StaticResource BrandDark}"/>
            <SolidColorBrush x:Key="BrandGrayBrush" Color="{StaticResource BrandGray}"/>

            <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
            <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}"/>
            <SolidColorBrush x:Key="AccentBlueBrush" Color="{StaticResource AccentBlue}"/>
            <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}"/>
            <SolidColorBrush x:Key="TextBrush" Color="#212121"/>
            <SolidColorBrush x:Key="BorderBrush" Color="#BDBDBD"/>

            <!-- Aliasy dla kompatybilności ze stylami widoków -->
            <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource BrandYellow}"/>
            <SolidColorBrush x:Key="PrimaryDarkBrush" Color="{StaticResource BrandYellowDark}"/>
            <SolidColorBrush x:Key="PrimaryLightBrush" Color="{StaticResource BrandYellowLight}"/>

            <!-- ============================================= -->
            <!-- TYPOGRAFIA — duża, czytelna                   -->
            <!-- ============================================= -->
            <Style TargetType="TextBlock">
                <Setter Property="FontSize" Value="16"/>
                <Setter Property="FontFamily" Value="Segoe UI"/>
                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            </Style>

            <Style x:Key="HeaderStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="26"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="Foreground" Value="{StaticResource BrandBlackBrush}"/>
                <Setter Property="Margin" Value="0,0,0,8"/>
            </Style>

            <Style x:Key="SubHeaderStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="19"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                <Setter Property="Margin" Value="0,0,0,5"/>
            </Style>

            <Style x:Key="LabelStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="15"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="#424242"/>
                <Setter Property="Margin" Value="0,6,0,3"/>
            </Style>

            <!-- ============================================= -->
            <!-- POLA TEKSTOWE                                 -->
            <!-- ============================================= -->
            <Style TargetType="TextBox">
                <Setter Property="FontSize" Value="17"/>
                <Setter Property="FontFamily" Value="Segoe UI"/>
                <Setter Property="Padding" Value="10,8"/>
                <Setter Property="Margin" Value="0,0,0,4"/>
                <Setter Property="MinHeight" Value="42"/>
                <Setter Property="BorderThickness" Value="2"/>
                <Setter Property="BorderBrush" Value="#BDBDBD"/>
                <Setter Property="Background" Value="White"/>
                <Style.Triggers>
                    <Trigger Property="IsFocused" Value="True">
                        <Setter Property="BorderBrush" Value="{StaticResource BrandYellowDarkBrush}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style TargetType="ComboBox">
                <Setter Property="FontSize" Value="17"/>
                <Setter Property="Padding" Value="10,8"/>
                <Setter Property="Margin" Value="0,0,0,4"/>
                <Setter Property="MinHeight" Value="42"/>
                <Setter Property="BorderThickness" Value="2"/>
                <Setter Property="BorderBrush" Value="#BDBDBD"/>
            </Style>

            <!-- ============================================= -->
            <!-- PRZYCISKI                                     -->
            <!-- ============================================= -->

            <!-- Główny - żółty JumpVolt -->
            <Style x:Key="PrimaryButton" TargetType="Button">
                <Setter Property="FontSize" Value="17"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="FontFamily" Value="Segoe UI"/>
                <Setter Property="Background" Value="{StaticResource BrandBlackBrush}"/>
                <Setter Property="Foreground" Value="{StaticResource BrandYellowBrush}"/>
                <Setter Property="Padding" Value="20,12"/>
                <Setter Property="Margin" Value="4"/>
                <Setter Property="MinHeight" Value="48"/>
                <Setter Property="MinWidth" Value="120"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" Background="{TemplateBinding Background}"
                                    CornerRadius="8" Padding="{TemplateBinding Padding}">
                                <TextBlock x:Name="text" Text="{TemplateBinding Content}"
                                           FontSize="{TemplateBinding FontSize}"
                                           FontWeight="{TemplateBinding FontWeight}"
                                           FontFamily="{TemplateBinding FontFamily}"
                                           Foreground="{TemplateBinding Foreground}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="{StaticResource BrandGrayBrush}"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Sukces - zielony -->
            <Style x:Key="SuccessButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                <Setter Property="Background" Value="{StaticResource SuccessBrush}"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="FontSize" Value="19"/>
                <Setter Property="MinHeight" Value="54"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" Background="{TemplateBinding Background}"
                                    CornerRadius="8" Padding="{TemplateBinding Padding}">
                                <TextBlock x:Name="text" Text="{TemplateBinding Content}"
                                           FontSize="{TemplateBinding FontSize}"
                                           FontWeight="{TemplateBinding FontWeight}"
                                           FontFamily="{TemplateBinding FontFamily}"
                                           Foreground="{TemplateBinding Foreground}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background">
                                        <Setter.Value><SolidColorBrush Color="#1B5E20"/></Setter.Value>
                                    </Setter>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Danger - czerwony -->
            <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                <Setter Property="Background" Value="{StaticResource DangerBrush}"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" Background="{TemplateBinding Background}"
                                    CornerRadius="8" Padding="{TemplateBinding Padding}">
                                <TextBlock x:Name="text" Text="{TemplateBinding Content}"
                                           FontSize="{TemplateBinding FontSize}"
                                           FontWeight="{TemplateBinding FontWeight}"
                                           FontFamily="{TemplateBinding FontFamily}"
                                           Foreground="{TemplateBinding Foreground}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background">
                                        <Setter.Value><SolidColorBrush Color="#B71C1C"/></Setter.Value>
                                    </Setter>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Accent - niebieski -->
            <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                <Setter Property="Background" Value="{StaticResource AccentBlueBrush}"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" Background="{TemplateBinding Background}"
                                    CornerRadius="8" Padding="{TemplateBinding Padding}">
                                <TextBlock x:Name="text" Text="{TemplateBinding Content}"
                                           FontSize="{TemplateBinding FontSize}"
                                           FontWeight="{TemplateBinding FontWeight}"
                                           FontFamily="{TemplateBinding FontFamily}"
                                           Foreground="{TemplateBinding Foreground}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background">
                                        <Setter.Value><SolidColorBrush Color="#0D47A1"/></Setter.Value>
                                    </Setter>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Nawigacja sidebar -->
            <Style x:Key="NavButton" TargetType="Button">
                <Setter Property="FontSize" Value="16"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="FontFamily" Value="Segoe UI"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="#FFD600"/>
                <Setter Property="Padding" Value="18,14"/>
                <Setter Property="Margin" Value="6,3"/>
                <Setter Property="MinHeight" Value="52"/>
                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" Background="{TemplateBinding Background}"
                                    CornerRadius="10" Padding="{TemplateBinding Padding}">
                                <!-- TextBlock z jawnym Foreground, nie ContentPresenter -->
                                <TextBlock x:Name="text" 
                                           Text="{TemplateBinding Content}"
                                           FontSize="{TemplateBinding FontSize}"
                                           FontWeight="{TemplateBinding FontWeight}"
                                           FontFamily="{TemplateBinding FontFamily}"
                                           Foreground="{TemplateBinding Foreground}"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background">
                                        <Setter.Value><SolidColorBrush Color="#FFD600"/></Setter.Value>
                                    </Setter>
                                    <Setter TargetName="text" Property="Foreground">
                                        <Setter.Value><SolidColorBrush Color="#1A1A1A"/></Setter.Value>
                                    </Setter>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ============================================= -->
            <!-- DATAGRID — żółte nagłówki                     -->
            <!-- ============================================= -->
            <Style TargetType="DataGrid">
                <Setter Property="FontSize" Value="15"/>
                <Setter Property="RowHeight" Value="44"/>
                <Setter Property="ColumnHeaderHeight" Value="48"/>
                <Setter Property="AutoGenerateColumns" Value="False"/>
                <Setter Property="CanUserAddRows" Value="False"/>
                <Setter Property="CanUserDeleteRows" Value="False"/>
                <Setter Property="IsReadOnly" Value="True"/>
                <Setter Property="SelectionMode" Value="Single"/>
                <Setter Property="GridLinesVisibility" Value="Horizontal"/>
                <Setter Property="HorizontalGridLinesBrush" Value="#E0E0E0"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="BorderBrush" Value="#E0E0E0"/>
                <Setter Property="Background" Value="White"/>
                <Setter Property="AlternatingRowBackground" Value="#FAFAFA"/>
            </Style>

            <Style TargetType="DataGridColumnHeader">
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="Background">
                    <Setter.Value><SolidColorBrush Color="#FFF9C4"/></Setter.Value>
                </Setter>
                <Setter Property="Foreground" Value="#1A1A1A"/>
                <Setter Property="Padding" Value="10,8"/>
                <Setter Property="BorderBrush" Value="#FFD600"/>
                <Setter Property="BorderThickness" Value="0,0,1,2"/>
            </Style>

            <!-- Karta -->
            <Style x:Key="CardPanel" TargetType="Border">
                <Setter Property="Background" Value="White"/>
                <Setter Property="CornerRadius" Value="10"/>
                <Setter Property="Padding" Value="16"/>
                <Setter Property="Margin" Value="6"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="BorderBrush" Value="#E0E0E0"/>
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect BlurRadius="6" ShadowDepth="1" Opacity="0.12" Color="Black"/>
                    </Setter.Value>
                </Setter>
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>
